{
  "name": "Google Maps Style Navigation",
  "short_name": "GMaps Nav",
  "start_url": "index.html",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#1a73e8",
  "description": "Navigation app with Google Maps style UI and real-time GPS tracking",
  "orientation": "portrait-primary",
  "id": "maps.navigation.app",
  "lang": "en",
  "dir": "ltr",
  "launch_handler": {
      "client_mode": ["navigate-existing", "auto"]
  },
  "display_override": [
    "window-controls-overlay",
    "standalone",
    "browser"
  ],
  "icons": [
    {
      "src": "icons/s3.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "icons/s4.png",
      "sizes": "768x768",
      "type": "image/png"
    }
  ],
  "screenshots": [
    {
      "src": "icons/s1.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide"
    },
    {
      "src": "icons/s2.png",
      "sizes": "360x640",
      "type": "image/png"
    }
  ],
  "prefer_related_applications": false
}
